#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AST_DISTANCE_BIN="$SCRIPT_DIR/ast_distance.bin"

# Guardrail: disable task-assignment/task-management features in this repo.
#
# Rationale: these ports must be driven by Rust→Kotlin transliteration work, not by
# task assignment plumbing or score-chasing. Parity-only commands remain enabled.
BLOCKED_FLAGS=(
  --init-tasks
  --tasks
  --assign
  --complete
  --unassign
)

for arg in "$@"; do
  for blocked in "${BLOCKED_FLAGS[@]}"; do
    if [[ "$arg" == "$blocked" ]]; then
      echo "Error: '$blocked' is disabled in this repo." >&2
      echo "Use parity-only commands like --deep, --compare-functions, --missing, --lint." >&2
      exit 2
    fi
  done
done

exec "$AST_DISTANCE_BIN" "$@"

